---
import { BUSINESS_INFO, OPENING_HOURS } from '@/lib/constants';
const googleMapsUrl = `https://maps.google.com/?q=${encodeURIComponent(BUSINESS_INFO.address.fullAddress)}`;
const mapsEmbedUrl = `https://www.google.com/maps?q=${encodeURIComponent(BUSINESS_INFO.address.fullAddress)}&output=embed&z=15`;
---

<section id="contact" class="bg-gradient-to-b from-cream via-terracotta-50/10 to-cream py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16">
      <span class="inline-block bg-sage-50 text-sage-dark font-body font-semibold text-sm uppercase tracking-wider px-4 py-1.5 rounded-full mb-4">
        Kontakt &amp; Terminbuchung
      </span>
      <h2 class="font-display text-olive text-3xl md:text-4xl mb-4">
        Besuchen Sie uns in <span class="text-sage">Erligheim</span>
      </h2>
      <p class="font-body text-text-muted max-w-2xl mx-auto text-base md:text-lg leading-relaxed">
        Wir freuen uns auf Ihren Besuch! Vereinbaren Sie einen Termin oder kontaktieren Sie uns f&uuml;r Fragen.
      </p>
    </div>

    <!-- Contact Info Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">

      <!-- Phone Card -->
      <a
        href={BUSINESS_INFO.contact.phoneHref}
        class="bg-warm-white border border-gold-light/30 rounded-organic-sm p-6 hover:border-gold hover:-translate-y-0.5 transition-all duration-300 group block"
      >
        <div class="w-12 h-12 bg-sage-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-sage-100 transition-colors">
          <svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
        </div>
        <p class="font-body font-semibold text-olive text-sm mb-1">Telefon</p>
        <p class="text-sage font-semibold font-body text-sm">{BUSINESS_INFO.contact.phoneFormatted}</p>
        <p class="text-text-muted text-xs mt-1 font-body">Mo-Fr: 9:00 - 15:00 Uhr</p>
      </a>

      <!-- Email Card -->
      <a
        href={BUSINESS_INFO.contact.emailHref}
        class="bg-warm-white border border-gold-light/30 rounded-organic-sm p-6 hover:border-gold hover:-translate-y-0.5 transition-all duration-300 group block"
      >
        <div class="w-12 h-12 bg-sage-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-sage-100 transition-colors">
          <svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
        </div>
        <p class="font-body font-semibold text-olive text-sm mb-1">E-Mail</p>
        <p class="text-sage font-semibold font-body text-sm break-all">{BUSINESS_INFO.contact.email}</p>
        <p class="text-text-muted text-xs mt-1 font-body">Wir antworten schnellstm&ouml;glich</p>
      </a>

      <!-- Address Card -->
      <a
        href={googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-warm-white border border-gold-light/30 rounded-organic-sm p-6 hover:border-gold hover:-translate-y-0.5 transition-all duration-300 group block"
      >
        <div class="w-12 h-12 bg-sage-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-sage-100 transition-colors">
          <svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
        </div>
        <p class="font-body font-semibold text-olive text-sm mb-1">Adresse</p>
        <p class="text-text-muted text-xs font-body leading-relaxed">
          {BUSINESS_INFO.address.street}<br />
          {BUSINESS_INFO.address.postalCode} {BUSINESS_INFO.address.city}<br />
          {BUSINESS_INFO.address.country}
        </p>
        <p class="text-sage text-xs font-semibold font-body mt-2 flex items-center gap-1 group-hover:underline">
          Route anzeigen
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 7h10v10" />
            <path d="M7 17 17 7" />
          </svg>
        </p>
      </a>

      <!-- Hours Card -->
      <div class="bg-warm-white border border-gold-light/30 rounded-organic-sm p-6">
        <div class="w-12 h-12 bg-sage-50 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
        </div>
        <p class="font-body font-semibold text-olive text-sm mb-2">&Ouml;ffnungszeiten</p>
        <div class="space-y-1">
          {OPENING_HOURS.map((entry) => (
            <div class="flex justify-between text-xs font-body">
              <span class="text-text-muted">{entry.days}</span>
              <span class={`font-medium ${entry.hours === 'Geschlossen' ? 'text-text-muted' : 'text-olive'}`}>
                {entry.hours}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Google Maps Embed -->
    <div class="rounded-organic overflow-hidden shadow-lg mb-12 aspect-video">
      <iframe
        src={mapsEmbedUrl}
        width="100%"
        height="100%"
        style="border: 0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Google Maps - Fußpflege bei Ella Schön in Erligheim"
      ></iframe>
    </div>

    <!-- Important Notes -->
    <div class="grid sm:grid-cols-2 gap-5 mb-12">
      <!-- Appointment Required -->
      <div class="bg-sage-50 border-2 border-sage-200 rounded-organic-sm p-6 flex items-start gap-4">
        <div class="w-10 h-10 bg-sage-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-sage" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" x2="12" y1="8" y2="12" />
            <line x1="12" x2="12.01" y1="16" y2="16" />
          </svg>
        </div>
        <div>
          <p class="font-body font-semibold text-olive text-sm mb-1">Terminvereinbarung erforderlich</p>
          <p class="text-text-muted text-xs font-body leading-relaxed">
            Bitte vereinbaren Sie vorab einen Termin per Telefon, E-Mail oder &uuml;ber unser Online-Formular.
            Termine au&szlig;erhalb der regul&auml;ren &Ouml;ffnungszeiten sind nach Absprache m&ouml;glich.
          </p>
        </div>
      </div>

      <!-- Cancellation Policy -->
      <div class="bg-amber-bg border-2 border-amber-border rounded-organic-sm p-6 flex items-start gap-4">
        <div class="w-10 h-10 bg-amber-border/30 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            <line x1="12" x2="12" y1="9" y2="13" />
            <line x1="12" x2="12.01" y1="17" y2="17" />
          </svg>
        </div>
        <div>
          <p class="font-body font-semibold text-olive text-sm mb-1">Stornierungsbedingungen</p>
          <p class="text-text-muted text-xs font-body leading-relaxed">
            Bitte sagen Sie Ihren Termin mindestens 24 Stunden vorher ab.
            Bei kurzfristiger Absage oder Nichterscheinen kann eine Ausfallgeb&uuml;hr berechnet werden.
          </p>
        </div>
      </div>
    </div>

    <!-- Booking Section -->
    <div id="booking" class="mt-16">
      <div class="text-center mb-10">
        <span class="inline-block bg-sage-50 text-sage-dark font-body font-semibold text-sm uppercase tracking-wider px-4 py-1.5 rounded-full mb-4">
          Termin buchen
        </span>
        <h2 class="font-display text-olive text-3xl md:text-4xl mt-4 mb-4">
          Vereinbaren Sie Ihren <span class="text-sage">Wunschtermin</span>
        </h2>
        <p class="font-body text-text-muted max-w-2xl mx-auto text-base leading-relaxed">
          F&uuml;llen Sie das Formular aus, um Ihren Wunschtermin anzufragen.
        </p>
      </div>
      <!-- BookingForm React island will be inserted here in index.astro -->
      <div id="booking-form-slot"></div>
    </div>

    <!-- Alternative Contact -->
    <div class="text-center mt-12">
      <p class="font-body text-text-muted mb-5">Oder kontaktieren Sie uns direkt:</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={BUSINESS_INFO.contact.phoneHref}
          class="inline-flex items-center gap-2 border-2 border-sage hover:bg-sage hover:text-white text-sage rounded-organic-sm px-6 py-3 font-body font-semibold text-sm transition-all duration-200"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          {BUSINESS_INFO.contact.phoneFormatted}
        </a>
        <a
          href={BUSINESS_INFO.contact.emailHref}
          class="inline-flex items-center gap-2 border-2 border-sage hover:bg-sage hover:text-white text-sage rounded-organic-sm px-6 py-3 font-body font-semibold text-sm transition-all duration-200"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          E-Mail schreiben
        </a>
      </div>
    </div>

  </div>
</section>
