---
import { MobileMenuToggle } from './react/MobileMenu';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <svg
          class="w-8 h-8 text-sage flex-shrink-0"
          viewBox="0 0 32 32"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M16 4C12 4 6 8 6 16c0 6 4 10 6 12 0-4 2-8 4-10 2 2 4 6 4 10 2-2 6-6 6-12C26 8 20 4 16 4z"
            fill="currentColor"
            opacity="0.85"
          />
          <path
            d="M16 10c-1 2-2 5-2 8M16 10c1 2 2 5 2 8"
            stroke="white"
            stroke-width="1.2"
            stroke-linecap="round"
            opacity="0.5"
          />
        </svg>
        <span class="hidden sm:block font-display text-olive text-lg sm:text-xl">
          Lena Schneider
        </span>
      </a>

      <!-- Desktop Navigation (center) -->
      <nav class="hidden lg:flex items-center gap-8">
        <a
          href="#services"
          class="nav-link font-body text-text-muted hover:text-sage transition-colors duration-200 text-sm tracking-wide"
          data-section="services"
        >
          Leistungen
        </a>
        <a
          href="#about"
          class="nav-link font-body text-text-muted hover:text-sage transition-colors duration-200 text-sm tracking-wide"
          data-section="about"
        >
          &Uuml;ber uns
        </a>
        <a
          href="#contact"
          class="nav-link font-body text-text-muted hover:text-sage transition-colors duration-200 text-sm tracking-wide"
          data-section="contact"
        >
          Kontakt
        </a>
        <a
          href="#booking"
          class="nav-link font-body text-text-muted hover:text-sage transition-colors duration-200 text-sm tracking-wide"
          data-section="booking"
        >
          Termin buchen
        </a>
      </nav>

      <!-- Desktop CTA (right) -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href="#booking"
          class="bg-terracotta hover:bg-terracotta-dark text-white rounded-organic-sm px-5 py-2.5 font-body font-bold text-sm transition-colors duration-200"
        >
          Termin buchen
        </a>
      </div>

      <!-- Mobile Controls -->
      <div class="flex lg:hidden items-center gap-3">
        <MobileMenuToggle client:load />
      </div>
    </div>
  </div>
</header>

<script>
  // Scroll detection: add .scrolled class for background transition
  const header = document.getElementById('site-header');

  function handleScroll() {
    if (!header) return;
    if (window.scrollY > 20) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // IntersectionObserver for active nav link highlighting
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link[data-section]');

  if (sections.length > 0 && navLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              const section = link.getAttribute('data-section');
              if (section === id) {
                link.classList.add('text-sage', 'font-semibold');
                link.classList.remove('text-text-muted');
              } else {
                link.classList.remove('text-sage', 'font-semibold');
                link.classList.add('text-text-muted');
              }
            });
          }
        });
      },
      {
        rootMargin: '-20% 0px -60% 0px',
        threshold: 0,
      }
    );

    sections.forEach((section) => observer.observe(section));
  }
</script>

<style>
  #site-header {
    background: transparent;
  }

  #site-header.scrolled {
    background: rgba(253, 246, 236, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 rgba(212, 165, 116, 0.15),
                0 4px 12px -4px rgba(74, 85, 64, 0.06);
  }
</style>
