---

---

<section
  id="hero"
  class="bg-cream grain relative overflow-hidden pt-24 pb-16 sm:pt-32 sm:pb-20 md:pt-40 md:pb-28"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 lg:gap-16 items-center">
      <!-- Text Column -->
      <div class="order-2 md:order-1">
        <h1 class="font-display text-olive text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
          Professionelle Fusspflege
          <span class="text-sage block mt-1">in Erligheim bei Ella Sch&ouml;n</span>
        </h1>

        <p class="font-body text-text-muted text-lg md:text-xl leading-relaxed mb-8 max-w-lg">
          Geniessen Sie professionelle kosmetische Fusspflege in einer angenehmen und
          entspannten Atmosph&auml;re. Ihr Wohlbefinden liegt uns am Herzen.
        </p>

        <!-- Highlights List -->
        <ul class="space-y-3 mb-10">
          <li class="flex items-start gap-3">
            <svg
              class="w-6 h-6 text-sage flex-shrink-0 mt-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 6L9 17l-5-5" />
            </svg>
            <span class="font-body text-olive text-base">Professionelle Kosmetische Fusspflege</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              class="w-6 h-6 text-sage flex-shrink-0 mt-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 6L9 17l-5-5" />
            </svg>
            <span class="font-body text-olive text-base">Angenehme Salon-Atmosph&auml;re</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              class="w-6 h-6 text-sage flex-shrink-0 mt-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 6L9 17l-5-5" />
            </svg>
            <span class="font-body text-olive text-base">Flexible Terminvereinbarung</span>
          </li>
        </ul>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 mb-8">
          <a
            href="#booking"
            class="inline-flex items-center gap-2 bg-terracotta hover:bg-terracotta-dark text-white px-8 py-4 rounded-organic-sm font-body font-bold text-base transition-colors duration-200"
          >
            <span>Termin buchen</span>
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14" />
              <path d="M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="tel:+4917634237368"
            class="inline-flex items-center gap-2 border-2 border-sage text-olive px-8 py-4 rounded-organic-sm font-body font-bold text-base hover:bg-sage/10 transition-colors duration-200"
          >
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            <span>Anrufen</span>
          </a>
        </div>

        <!-- Trust Badges -->
        <div class="flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-2 bg-sage-50 rounded-full px-4 py-2 font-body text-sm text-olive">
            <svg
              class="w-4 h-4 text-sage"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            Zertifiziert
          </span>
          <span class="inline-flex items-center gap-2 bg-sage-50 rounded-full px-4 py-2 font-body text-sm text-olive">
            <svg
              class="w-4 h-4 text-sage"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="8" r="7" />
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" />
            </svg>
            Qualifiziert
          </span>
        </div>
      </div>

      <!-- Image Column -->
      <div class="order-1 md:order-2 relative flex justify-center">
        <!-- Decorative blurred circles -->
        <div
          class="absolute -top-10 -right-10 w-64 h-64 bg-sage/20 rounded-full blur-3xl"
          aria-hidden="true"
        ></div>
        <div
          class="absolute -bottom-10 -left-10 w-48 h-48 bg-gold-light/30 rounded-full blur-3xl"
          aria-hidden="true"
        ></div>

        <!-- Hero Image -->
        <div class="relative">
          <img
            src="/hero-gemini.jpeg"
            alt="Professionelle Fusspflege im Salon von Lena Schneider in Erligheim"
            loading="eager"
            width="560"
            height="640"
            class="hero-image relative z-10 w-full max-w-md lg:max-w-lg object-cover border-4 border-gold-light shadow-xl"
          />

          <!-- Floating Card -->
          <div
            class="hidden lg:flex absolute -bottom-6 -left-8 z-20 items-center gap-3 bg-white/90 backdrop-blur-sm rounded-2xl shadow-lg px-5 py-4 border border-gold-light/20"
          >
            <div class="flex items-center justify-center w-10 h-10 bg-gold-light/20 rounded-full">
              <svg
                class="w-5 h-5 text-gold"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            </div>
            <div>
              <p class="font-body font-bold text-olive text-sm">100% Zufriedenheit</p>
              <p class="font-body text-text-muted text-xs">Unsere Kunden lieben uns</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-image {
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
  }
</style>
