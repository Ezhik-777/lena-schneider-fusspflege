---
import { SERVICES } from '@/lib/constants';

const serviceIcons: Record<string, string> = {
  "smart-pediküre": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark"><path d="M12 2L9.5 8.5 3 10l5 4.5L6.5 21 12 17.5 17.5 21 16 14.5 21 10l-6.5-1.5z"/></svg>`,
  "klassische-fußpflege": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark"><path d="M7 21c0 0 1-3 1-6s-1-5-1-7c0-3 2-6 5-6s5 3 5 6c0 2-1 4-1 7s1 6 1 6"/><path d="M12 2v0"/><circle cx="9.5" cy="16" r="0.5" fill="currentColor"/><circle cx="14.5" cy="16" r="0.5" fill="currentColor"/><circle cx="10" cy="13" r="0.5" fill="currentColor"/><circle cx="14" cy="13" r="0.5" fill="currentColor"/><circle cx="12" cy="10" r="0.5" fill="currentColor"/></svg>`,
  "massage": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark"><path d="M2 12c2-2 4-3 6-3s4 2 6 2 4-2 6-2"/><path d="M2 17c2-2 4-3 6-3s4 2 6 2 4-2 6-2"/><path d="M2 7c2-2 4-3 6-3s4 2 6 2 4-2 6-2"/></svg>`,
  "nagelkorrektur": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="18" r="3"/><path d="M8.12 8.12L17 17"/><path d="M16 2l6 6"/><path d="M2 16l6 6"/></svg>`,
  "fremdmodellage-entfernen": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark"><path d="M12 2v6"/><path d="M8 4.5c0 0 1 2.5 4 2.5s4-2.5 4-2.5"/><path d="M12 8c-4 0-6 4-6 7 0 4 2.5 7 6 7s6-3 6-7c0-3-2-7-6-7z"/></svg>`,
  "natuerliche-manikuere": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark"><path d="M18 11V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 17"/></svg>`,
  "paraffinbehandlung": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7 text-sage-dark"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.07-2.14 0-5.5 2.5-7 0 1.5.5 2 1.5 3C15 6.5 16 8 16 10.5a4.5 4.5 0 0 1-7 3.74"/><path d="M3 19h18"/><path d="M5 19v2h14v-2"/></svg>`,
};
---

<section id="services" class="bg-cream relative py-16 md:py-24">
  <!-- Wave divider at top -->
  <div class="absolute top-0 left-0 right-0 h-16 bg-cream" style="clip-path: ellipse(60% 100% at 50% 100%); margin-top: -60px; z-index: 2;"></div>

  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16 reveal">
      <span class="inline-block bg-sage-50 text-sage-dark font-body font-semibold text-sm uppercase tracking-wider px-4 py-2 rounded-full mb-4">
        Unsere Leistungen
      </span>
      <h2 class="font-display text-olive text-3xl md:text-4xl mb-4">
        Professionelle Fußpflege &amp; Wellness
      </h2>
      <p class="font-body text-text-muted max-w-2xl mx-auto text-base md:text-lg leading-relaxed">
        Entdecken Sie unser vielfältiges Angebot an Pflege- und Wellness-Behandlungen für Ihre Füße und Hände.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 stagger-children">
      {SERVICES.map((service) => (
        <article class="card-hover bg-warm-white rounded-organic-sm border border-gold-light/20 hover:border-gold flex flex-col">
          {/* Card Header */}
          <div class="bg-sage-50/50 p-6 text-center rounded-t-organic-sm">
            <div class="w-14 h-14 bg-sage-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <Fragment set:html={serviceIcons[service.id] || ''} />
            </div>
            <h3 class="font-display text-olive text-xl">{service.title}</h3>
          </div>

          {/* Card Body */}
          <div class="p-6 flex flex-col flex-grow">
            <p class="text-text-muted text-sm leading-relaxed">{service.description}</p>

            {service.note && (
              <p class="text-text-muted/70 text-xs italic mt-2">{service.note}</p>
            )}

            {/* Benefits List */}
            <ul class="mt-4 space-y-2">
              {service.benefits.map((benefit) => (
                <li class="flex items-start text-sm text-text-dark">
                  <span class="text-sage font-bold mr-2">✓</span>
                  <span>{benefit}</span>
                </li>
              ))}
            </ul>

            {/* Divider */}
            <div class="border-t border-gold-light/30 pt-4 mt-auto">
              {service.priceOptions ? (
                <div>
                  {/* Duration */}
                  <div class="flex items-center gap-1.5 text-text-muted text-sm mb-3">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10" />
                      <line x1="12" y1="6" x2="12" y2="12" />
                      <line x1="12" y1="12" x2="16" y2="14" />
                    </svg>
                    <span class="font-body">{service.duration}</span>
                  </div>
                  {/* Price Options */}
                  <div class="space-y-2">
                    {service.priceOptions.map((option) => (
                      <div class="bg-sage-50 rounded-lg px-3 py-2 flex justify-between">
                        <span class="font-body text-sm text-text-dark">{option.label}</span>
                        <span class="font-body text-terracotta font-bold text-sm">{option.price}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ) : (
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5 text-text-muted text-sm">
                    <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10" />
                      <line x1="12" y1="6" x2="12" y2="12" />
                      <line x1="12" y1="12" x2="16" y2="14" />
                    </svg>
                    <span class="font-body">{service.duration}</span>
                  </div>
                  <span class="text-terracotta font-bold text-lg font-body">{service.price}</span>
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- New Customer Discount Banner -->
    <div class="reveal bg-gradient-to-br from-terracotta-50 to-cream border-2 border-gold-light rounded-organic p-8 text-center mt-12">
      <h3 class="font-display text-olive text-xl md:text-2xl mb-2">Neukunden-Rabatt</h3>
      <p class="text-terracotta font-display text-3xl mb-1">10% Rabatt</p>
      <p class="font-body text-text-muted text-base">auf Ihre erste Behandlung</p>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-10 reveal">
      <button
        onclick="document.getElementById('booking')?.scrollIntoView({ behavior: 'smooth' })"
        class="btn-primary inline-block bg-terracotta hover:bg-terracotta-dark text-white rounded-organic-sm px-8 py-3.5 font-body font-bold text-base cursor-pointer"
      >
        Jetzt Termin vereinbaren
      </button>
    </div>
  </div>
</section>
