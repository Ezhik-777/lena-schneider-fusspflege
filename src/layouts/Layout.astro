---
import '@/styles/global.css';
import {
  BUSINESS_INFO,
  FAQ_ITEMS,
  OPENING_HOURS,
  SERVICE_CATEGORIES,
  SITE_ASSETS,
} from '@/lib/constants';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

type ServiceEntry = {
  title: string;
  price?: string;
  description?: string;
  note?: string;
  priceOptions?: Array<{
    label: string;
    price: string;
  }>;
};

const {
  title = BUSINESS_INFO.seo.title,
  description = BUSINESS_INFO.seo.description,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? BUSINESS_INFO.seo.domain);
const ogImageURL = new URL(SITE_ASSETS.ogImage, BUSINESS_INFO.seo.domain);
const gaId = import.meta.env.PUBLIC_GA_ID;

const parsePrice = (price: string) => price.replace(/[^\d,]/g, '').replace(',', '.');

const serviceCatalog = SERVICE_CATEGORIES.map((category) => {
  const services = category.services as ServiceEntry[];

  return {
    '@type': 'OfferCatalog',
    name: category.title,
    itemListElement: services.flatMap((service) => {
      if (service.priceOptions?.length) {
        return service.priceOptions.map((option) => ({
          '@type': 'Offer',
          price: parsePrice(option.price),
          priceCurrency: 'EUR',
          itemOffered: {
            '@type': 'Service',
            name: `${service.title} ${option.label}`,
            description: service.description ?? service.note ?? service.title,
          },
        }));
      }

      if (!service.price) {
        return [];
      }

      return [{
        '@type': 'Offer',
        price: parsePrice(service.price),
        priceCurrency: 'EUR',
        itemOffered: {
          '@type': 'Service',
          name: service.title,
          description: service.description ?? service.note ?? service.title,
        },
      }];
    }),
  };
});

const openingHoursSpecification = OPENING_HOURS
  .filter((entry) => entry.hours !== 'Geschlossen')
  .map((entry) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: entry.schemaDays,
    opens: '09:00',
    closes: '15:00',
  }));

const localBusinessStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BeautySalon',
  '@id': `${BUSINESS_INFO.seo.domain}/#business`,
  name: BUSINESS_INFO.name,
  alternateName: BUSINESS_INFO.alternateNames,
  description,
  url: BUSINESS_INFO.seo.domain,
  telephone: BUSINESS_INFO.contact.phoneHref.replace('tel:', ''),
  email: BUSINESS_INFO.contact.email,
  image: ogImageURL.toString(),
  priceRange: BUSINESS_INFO.priceRange,
  currenciesAccepted: 'EUR',
  paymentAccepted: BUSINESS_INFO.paymentAccepted.join(', '),
  founder: {
    '@type': 'Person',
    name: BUSINESS_INFO.owner,
    jobTitle: 'Kosmetische Fußpflegerin',
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: BUSINESS_INFO.address.street,
    addressLocality: BUSINESS_INFO.address.city,
    postalCode: BUSINESS_INFO.address.postalCode,
    addressRegion: BUSINESS_INFO.address.region,
    addressCountry: 'DE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: BUSINESS_INFO.geo.latitude,
    longitude: BUSINESS_INFO.geo.longitude,
  },
  openingHoursSpecification,
  areaServed: BUSINESS_INFO.areaServed.map((name) => ({
    '@type': name.startsWith('Landkreis') ? 'AdministrativeArea' : 'City',
    name,
  })),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Fußpflege & Maniküre Leistungen',
    itemListElement: serviceCatalog,
  },
  hasMap: BUSINESS_INFO.social.googleBusiness,
  sameAs: [
    BUSINESS_INFO.social.googleBusiness,
    BUSINESS_INFO.social.instagram,
    BUSINESS_INFO.social.tiktok,
  ],
};

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta name="author" content={BUSINESS_INFO.owner} />
    <meta name="creator" content={BUSINESS_INFO.owner} />
    <meta name="publisher" content={BUSINESS_INFO.name} />
    <link rel="canonical" href={canonicalURL} />

    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta
        name="robots"
        content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
      />
    )}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={BUSINESS_INFO.seo.locale} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={BUSINESS_INFO.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.toString()} />
    <meta property="og:image:width" content={String(SITE_ASSETS.ogImageWidth)} />
    <meta property="og:image:height" content={String(SITE_ASSETS.ogImageHeight)} />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.toString()} />

    <meta name="geo.region" content="DE-BW" />
    <meta name="geo.placename" content={BUSINESS_INFO.address.city} />
    <meta name="geo.position" content={`${BUSINESS_INFO.geo.latitude};${BUSINESS_INFO.geo.longitude}`} />
    <meta name="ICBM" content={`${BUSINESS_INFO.geo.latitude}, ${BUSINESS_INFO.geo.longitude}`} />
    <meta name="city" content={BUSINESS_INFO.address.city} />
    <meta name="state" content={BUSINESS_INFO.address.region} />
    <meta name="country" content="Germany" />
    <meta name="language" content="German" />
    <meta name="distribution" content="local" />

    <meta name="contact" content={BUSINESS_INFO.contact.email} />
    <meta name="telephone" content={BUSINESS_INFO.contact.phoneHref.replace('tel:', '')} />
    <meta name="address" content={BUSINESS_INFO.address.fullAddress} />

    <meta name="format-detection" content="telephone=yes" />
    <meta name="theme-color" content={BUSINESS_INFO.seo.themeColor} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={BUSINESS_INFO.name} />

    <link rel="icon" href={SITE_ASSETS.favicon} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={SITE_ASSETS.appleTouchIcon} />
    <link rel="manifest" href={SITE_ASSETS.manifest} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://maps.googleapis.com" />
    <link rel="preconnect" href="https://api.telegram.org" />

    {gaId && (
      <script is:inline define:vars={{ gaId }}>
        (() => {
          const consentKey = 'cookieConsent';
          const disableKey = `ga-disable-${gaId}`;

          const hasAnalyticsConsent = () => {
            try {
              const rawValue = window.localStorage.getItem(consentKey);
              if (!rawValue) return false;
              const preferences = JSON.parse(rawValue);
              return Boolean(preferences?.analytics);
            } catch {
              return false;
            }
          };

          const updateConsent = (granted) => {
            window[disableKey] = !granted;
            if (window.gtag) {
              window.gtag('consent', 'update', {
                analytics_storage: granted ? 'granted' : 'denied',
              });
            }
          };

          const loadAnalytics = () => {
            if (window.__gaInitialized) {
              updateConsent(true);
              return;
            }

            window.dataLayer = window.dataLayer || [];
            window.gtag = window.gtag || function () {
              window.dataLayer.push(arguments);
            };
            window.gtag('consent', 'default', { analytics_storage: 'denied' });

            const script = document.createElement('script');
            script.async = true;
            script.src = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
            document.head.appendChild(script);

            window.gtag('js', new Date());
            window.gtag('config', gaId, { anonymize_ip: true });
            window.__gaInitialized = true;
            updateConsent(true);
          };

          const syncAnalytics = () => {
            if (hasAnalyticsConsent()) {
              loadAnalytics();
            } else {
              updateConsent(false);
            }
          };

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', syncAnalytics, { once: true });
          } else {
            syncAnalytics();
          }

          window.addEventListener('cookie-consent-updated', syncAnalytics);
        })();
      </script>
    )}

    <script type="application/ld+json" set:html={JSON.stringify(localBusinessStructuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
  </head>
  <body class="font-body bg-cream text-text-dark">
    <div class="sr-only focus-within:not-sr-only focus-within:absolute focus-within:top-4 focus-within:left-4 focus-within:z-[100] focus-within:flex focus-within:gap-2">
      <a href="#main-content" class="px-4 py-2 bg-sage text-white rounded-lg shadow-lg font-semibold">
        Zum Hauptinhalt springen
      </a>
      <a href="#services" class="px-4 py-2 bg-sage text-white rounded-lg shadow-lg font-semibold">
        Zu Leistungen springen
      </a>
      <a href="#booking" class="px-4 py-2 bg-sage text-white rounded-lg shadow-lg font-semibold">
        Zur Terminbuchung springen
      </a>
    </div>

    <slot />

    <script is:inline>
      (function() {
        const selectors = '.reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children';
        const observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll(selectors).forEach(function(el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
