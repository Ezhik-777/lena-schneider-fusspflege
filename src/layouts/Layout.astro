---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = 'Fusspflege Erligheim bei Ella Schon | Lena Schneider | Kosmetische Fusspflege & Pedikure',
  description = 'Professionelle kosmetische Fusspflege in Erligheim bei Ella Schon. Smart Pedikure, Klassische Fusspflege, Manikure. Termine nach Vereinbarung. +49 176 34237368',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Fusspflege Erligheim, Kosmetische Fusspflege Erligheim, Fusspflegerin Erligheim, Pedikure Erligheim, Fusspflege bei Ella Schon, Smart Pedikure, Klassische Fusspflege, Nagelmodellage, Japanische Manikure, Maniküre Erligheim, Fusspflege Bonnigheim, Fusspflege Besigheim, Fusspflege Sachsenheim, Fusspflege Bietigheim-Bissingen, Fusspflege Freudental, Fusspflege Lochgau, Fusspflege Kirchheim am Neckar, Fusspflege Walheim, Fusspflege Ludwigsburg Kreis, Hornhautentfernung, Nagelkorrektur, Fusspflege Termin buchen, Professionelle Fusspflege, Fusspflege Preise, Kosmetische Fusspflege Baden-Wurttemberg, Fusspflege 74391, Fusspflege Landkreis Ludwigsburg" />

    <meta name="author" content="Lena Schneider" />
    <meta name="creator" content="Lena Schneider" />
    <meta name="publisher" content="Fusspflege Lena Schneider" />
    <link rel="canonical" href={canonicalURL} />

    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Fusspflege Lena Schneider Erligheim bei Ella Schon" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <!-- Geo & Local SEO -->
    <meta name="geo.region" content="DE-BW" />
    <meta name="geo.placename" content="Erligheim" />
    <meta name="geo.position" content="48.9615;9.0667" />
    <meta name="ICBM" content="48.9615, 9.0667" />
    <meta name="city" content="Erligheim" />
    <meta name="state" content="Baden-Wurttemberg" />
    <meta name="country" content="Germany" />
    <meta name="language" content="German" />
    <meta name="distribution" content="local" />

    <!-- Contact -->
    <meta name="contact" content="info@fusspflege-lena-schneider.de" />
    <meta name="telephone" content="+4917634237368" />
    <meta name="address" content="Lochgauer str. 17, 74391 Erligheim" />

    <!-- Mobile -->
    <meta name="format-detection" content="telephone=yes" />
    <meta name="theme-color" content="#8B9E7E" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Fusspflege Erligheim" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/icon-192x192.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- DNS Prefetch -->
    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://maps.googleapis.com" />
    <link rel="preconnect" href="https://api.telegram.org" />

    <!-- Google Analytics -->
    {gaId && (
      <>
        <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} async></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BeautySalon",
      "@id": "https://fusspflege-lena-schneider.de/#business",
      "name": "Fusspflege Lena Schneider",
      "alternateName": ["Fusspflege Erligheim bei Ella Schoen", "Unser Salon bei Ella Schoen"],
      "description": "Professionelle kosmetische Fusspflege, Pedikuere und Manikuere in Erligheim bei Ella Schoen. Inhaberin Elena Schneider bietet mehrfach zertifizierte Behandlungen in gemuetlicher Salon-Atmosphaere.",
      "url": "https://fusspflege-lena-schneider.de",
      "telephone": "+4917634237368",
      "email": "info@fusspflege-lena-schneider.de",
      "image": "https://fusspflege-lena-schneider.de/nails-work.jpg",
      "priceRange": "25-60 EUR",
      "currenciesAccepted": "EUR",
      "paymentAccepted": "Cash, Debit Card",
      "founder": {
        "@type": "Person",
        "name": "Elena Schneider",
        "jobTitle": "Kosmetische Fusspflegerin"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Loechgauer Str. 17",
        "addressLocality": "Erligheim",
        "postalCode": "74391",
        "addressRegion": "Baden-Wuerttemberg",
        "addressCountry": "DE"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 48.9615, "longitude": 9.0667 },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "15:00" }
      ],
      "areaServed": [
        {"@type":"City","name":"Erligheim"},{"@type":"City","name":"Boennigheim"},{"@type":"City","name":"Besigheim"},
        {"@type":"City","name":"Sachsenheim"},{"@type":"City","name":"Bietigheim-Bissingen"},{"@type":"City","name":"Freudental"},
        {"@type":"City","name":"Loechgau"},{"@type":"City","name":"Kirchheim am Neckar"},{"@type":"City","name":"Walheim"},
        {"@type":"City","name":"Muendelsheim"},{"@type":"City","name":"Gemmrigheim"},{"@type":"City","name":"Vaihingen an der Enz"},
        {"@type":"City","name":"Markgroeningen"},{"@type":"City","name":"Ludwigsburg"},
        {"@type":"AdministrativeArea","name":"Landkreis Ludwigsburg"}
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Fusspflege & Manikuere Leistungen",
        "itemListElement": [
          {"@type":"OfferCatalog","name":"Fusspflege","itemListElement":[
            {"@type":"Offer","price":"37.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Klassische Fusspflege","description":"Professionelle kosmetische Fusspflege: Naegel schneiden, Nagelhautentfernung, Hornhautentfernung. Ca. 45 Min."}},
            {"@type":"Offer","price":"60.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Smart Pedikuere","description":"Moderne Fusspflege: sanfte Hornhautentfernung, Naegel formen, Hautpflege mit Pflegeoel. Ca. 50 Min."}},
            {"@type":"Offer","price":"59.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Verwoehnpaket","description":"Rundum-Sorglos-Paket inkl. Fusspflege, Peeling und entspannende Massage. Ca. 60 Min."}},
            {"@type":"Offer","price":"29.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Kosmetische Nagelkorrektur","description":"Kaum sichtbare, sanfte kosmetische Methode. Pro Nagel (ohne Fusspflege). Ca. 10 Min."}}
          ]},
          {"@type":"OfferCatalog","name":"Manikuere","itemListElement":[
            {"@type":"Offer","price":"25.50","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Manikuere","description":"Naegel kuerzen, feilen und in Form bringen. Ca. 30 Min."}},
            {"@type":"Offer","price":"55.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Neumodellage / Gel / Tips","description":"Professioneller Neuaufbau mit Gel oder Tips. Ca. 90 Min."}},
            {"@type":"Offer","price":"45.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Auffuellen / Refill bis 4 Wochen","description":"Professionelles Auffuellen der Naegel. Ca. 60 Min."}},
            {"@type":"Offer","price":"55.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Auffuellen / Refill ab 5 Wochen","description":"Professionelles Auffuellen der Naegel. Ca. 60 Min."}},
            {"@type":"Offer","price":"50.00","priceCurrency":"EUR","itemOffered":{"@type":"Service","name":"Japanische Manikuere","description":"Natuerliche Pflege fuer gesunde, glaenzende Naegel ohne Gel oder Acryl. Ca. 45 Min."}}
          ]}
        ]
      }
    })} />

    <!-- Structured Data: FAQ -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"Wo befindet sich die Fusspflege in Erligheim?","acceptedAnswer":{"@type":"Answer","text":"Unser Salon befindet sich bei Ella Schoen in Erligheim, Loechgauer Str. 17, 74391 Erligheim (Landkreis Ludwigsburg, Baden-Wuerttemberg). Inhaberin ist Elena Schneider."}},
        {"@type":"Question","name":"Was kostet eine Fusspflege in Erligheim?","acceptedAnswer":{"@type":"Answer","text":"Klassische Fusspflege kostet 37 EUR (ca. 45 Min.), die Smart Pedikuere 60 EUR (ca. 50 Min.) und das Verwoehnpaket inkl. Peeling und Massage 59 EUR (ca. 60 Min.). Zusatzoptionen wie Shellac (+18 EUR) oder Nagellack (+8 EUR) sind moeglich."}},
        {"@type":"Question","name":"Welche Manikuere-Leistungen werden angeboten?","acceptedAnswer":{"@type":"Answer","text":"Wir bieten Manikuere (25,50 EUR), Neumodellage mit Gel/Tips (55 EUR), Auffuellen/Refill (45-55 EUR je nach Zeitraum) und Japanische Manikuere (50 EUR) an."}},
        {"@type":"Question","name":"Brauche ich einen Termin fuer die Fusspflege?","acceptedAnswer":{"@type":"Answer","text":"Ja, wir arbeiten ausschliesslich nach Terminvereinbarung. Sie koennen telefonisch (+49 176 34237368), per E-Mail (info@fusspflege-lena-schneider.de) oder ueber unser Online-Buchungsformular auf der Website einen Termin buchen."}},
        {"@type":"Question","name":"Wann hat die Fusspflege in Erligheim geoeffnet?","acceptedAnswer":{"@type":"Answer","text":"Unsere Oeffnungszeiten sind Montag bis Freitag von 09:00 bis 15:00 Uhr. Samstag und Sonntag ist geschlossen. Termine ausserhalb der regulaeren Zeiten sind nach Absprache moeglich."}},
        {"@type":"Question","name":"Was ist die Smart Pedikuere?","acceptedAnswer":{"@type":"Answer","text":"Die Smart Pedikuere ist unsere empfohlene moderne Form der Fusspflege. Hornhaut wird sanft entfernt, die Naegel werden geformt und die Haut mit Pflegeoel gepflegt. Das sorgt fuer glatte, gepflegte Fuesse und ein langanhaltendes Frischegefuehl. Preis: 60 EUR, Dauer: ca. 50 Min."}},
        {"@type":"Question","name":"Gibt es Gutscheine fuer Fusspflege?","acceptedAnswer":{"@type":"Answer","text":"Ja, Gutscheine sind erhaeltlich! Das perfekte Geschenk fuer liebe Menschen. Fragen Sie einfach bei uns nach."}},
        {"@type":"Question","name":"Was muss ich zur Fusspflege mitbringen?","acceptedAnswer":{"@type":"Answer","text":"Bitte bringen Sie ein kleines Handtuch zur Fusspflege mit."}},
        {"@type":"Question","name":"Wie sind die Stornierungsbedingungen?","acceptedAnswer":{"@type":"Answer","text":"Bitte sagen Sie Ihren Termin mindestens 24 Stunden vorher ab. Bei kurzfristiger Absage oder Nichterscheinen kann eine Ausfallgebuehr berechnet werden."}}
      ]
    })} />
  </head>
  <body class="font-body bg-cream text-text-dark">
    <!-- Skip navigation -->
    <div class="sr-only focus-within:not-sr-only focus-within:absolute focus-within:top-4 focus-within:left-4 focus-within:z-[100] focus-within:flex focus-within:gap-2">
      <a href="#main-content" class="px-4 py-2 bg-sage text-white rounded-lg shadow-lg font-semibold">
        Zum Hauptinhalt springen
      </a>
      <a href="#services" class="px-4 py-2 bg-sage text-white rounded-lg shadow-lg font-semibold">
        Zu Leistungen springen
      </a>
      <a href="#booking" class="px-4 py-2 bg-sage text-white rounded-lg shadow-lg font-semibold">
        Zur Terminbuchung springen
      </a>
    </div>

    <slot />

    <!-- Scroll Reveal Observer -->
    <script is:inline>
      (function() {
        const selectors = '.reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children';
        const observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll(selectors).forEach(function(el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
